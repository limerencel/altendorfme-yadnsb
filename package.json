{
    "name": "yadnsb",
    "version": "1.0.0",
    "description": "Yet Another DNS Benchmark",
    "main": "server.js",
    "type": "module",
    "scripts": {
        "start": "node server.js",
        "dev": "node --watch server.js",
        "test": "node --test tests/**/*.test.js",
        "build": "echo 'Build completed'",
        "docker:build": "docker build -t yadnsb .",
        "docker:run": "docker run -d -p 3000:3000 --name yadnsb yadnsb",
        "docker:stop": "docker stop yadnsb && docker rm yadnsb",
        "docker:logs": "docker logs -f yadnsb",
        "docker:compose:up": "docker-compose up -d",
        "docker:compose:down": "docker-compose down",
        "docker:compose:logs": "docker-compose logs -f"
    },
    "keywords": [
        "dns",
        "benchmark",
        "performance",
        "doh",
        "dot",
        "doq"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "@matrixai/quic": "^2.0.9",
        "dohjs": "^0.3.3",
        "express": "^5.2.1",
        "ws": "^8.21.0"
    },
    "engines": {
        "node": ">=22.0.0"
    },
    "devDependencies": {
        "cross-env": "^10.1.0"
    }
}
